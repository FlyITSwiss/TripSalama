    right: var(--space-3);
    background: transparent;
    border: none;
    cursor: pointer;
    padding: var(--space-2);
    color: var(--color-text-muted);
    transition: color var(--transition-fast);
}

.password-toggle:hover {
    color: var(--color-text);
}

.form-hint {
    font-size: var(--text-xs);
