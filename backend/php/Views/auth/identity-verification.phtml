    <!-- Module Identity Camera -->
    <script src="<?= versioned_asset('js/modules/identity-camera.js') ?>"></script>

    <script>
        // Fonction appelée quand la vérification est terminée
        window.onVerificationComplete = function(result) {
            AppConfig.log('Vérification terminée:', result);

            if (result && (result.status === 'verified' || result.status === 'pending' || result.status === 'manual_review')) {
                // Rediriger vers la page suivante
                if (typeof navigateTo === 'function') {
                    navigateTo('dashboard');
                } else {
                    window.location.href = AppConfig.basePath + '/dashboard';
                }
            }
        };

        // Initialiser le module Identity Camera APRÈS que i18n soit chargé
        document.addEventListener('DOMContentLoaded', async function() {
            // Attendre que i18n soit initialisé
            if (typeof i18n !== 'undefined' && !i18n.isReady()) {
                await i18n.init(AppConfig.lang);
            }

            // Petit délai pour s'assurer que tout est prêt
            await new Promise(resolve => setTimeout(resolve, 100));

            if (typeof IdentityCamera !== 'undefined') {
                IdentityCamera.init('#identity-camera-container', {
                    onComplete: 'onVerificationComplete'
                });
            } else {
                console.error('Module IdentityCamera non chargé');
            }
        });
    </script>

