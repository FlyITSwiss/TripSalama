    <style>
        .register-page { min-height: 100vh; display: flex; flex-direction: column; background: var(--uber-white); }
        .register-header { padding: var(--space-12) var(--space-6) var(--space-6); text-align: center; }
        .register-logo { font-size: 48px; font-weight: 800; color: var(--uber-black); letter-spacing: -0.04em; margin-bottom: var(--space-6); }
        .register-logo span { color: var(--uber-green); }
        .register-title { font-size: var(--text-2xl); font-weight: var(--font-bold); color: var(--uber-black); margin-bottom: var(--space-2); }
        .register-subtitle { font-size: var(--text-base); color: var(--uber-gray-500); }
        .register-content { flex: 1; padding: var(--space-6); }
        .role-cards { display: flex; flex-direction: column; gap: var(--space-4); }
        .role-card { display: flex; align-items: center; gap: var(--space-4); padding: var(--space-5); background: var(--uber-gray-50); border: 2px solid transparent; border-radius: var(--radius-xl); text-decoration: none; color: inherit; transition: all 0.2s ease; }
        .role-card:hover { background: var(--uber-white); border-color: var(--uber-black); transform: translateY(-2px); box-shadow: var(--shadow-lg); }
        .role-icon { width: 56px; height: 56px; display: flex; align-items: center; justify-content: center; border-radius: var(--radius-lg); flex-shrink: 0; }
        .role-icon.passenger { background: var(--uber-green-soft); color: var(--uber-green); }
        .role-icon.driver { background: #EBF5FF; color: #0066FF; }
        .role-icon svg { width: 28px; height: 28px; }
        .role-info { flex: 1; }
        .role-title { font-size: var(--text-lg); font-weight: var(--font-semibold); color: var(--uber-black); margin-bottom: var(--space-1); }
        .role-description { font-size: var(--text-sm); color: var(--uber-gray-500); }
        .role-arrow { width: 24px; height: 24px; color: var(--uber-gray-400); flex-shrink: 0; }
        .register-footer { padding: var(--space-6); text-align: center; background: var(--uber-gray-50); }
        .register-footer-text { font-size: var(--text-sm); color: var(--uber-gray-500); margin-bottom: var(--space-4); }
        .register-footer-btn { width: 100%; padding: var(--space-4); font-family: var(--font-family); font-size: var(--text-base); font-weight: var(--font-semibold); color: var(--uber-black); background: var(--uber-gray-100); border: none; border-radius: var(--radius-lg); text-decoration: none; display: block; }
        .register-footer-btn:hover { background: var(--uber-gray-200); }
        @media (min-width: 480px) {
            .register-page { justify-content: center; background: var(--uber-gray-100); padding: var(--space-6); }
            .register-container { max-width: 420px; margin: 0 auto; background: var(--uber-white); border-radius: var(--radius-2xl); box-shadow: var(--shadow-xl); overflow: hidden; }
        }
