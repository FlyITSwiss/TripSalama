    <script>
    (function() {
        'use strict';

        // Elements
        const form = document.getElementById('registerForm');
        const submitBtn = document.getElementById('submitBtn');

        const firstName = document.getElementById('first_name');
        const lastName = document.getElementById('last_name');
        const email = document.getElementById('email');
        const phone = document.getElementById('phone');
        const password = document.getElementById('password');
        const passwordConfirm = document.getElementById('password_confirm');
        const vehicleBrand = document.getElementById('vehicle_brand');
        const vehicleModel = document.getElementById('vehicle_model');
        const vehicleColor = document.getElementById('vehicle_color');
        const vehicleLicensePlate = document.getElementById('vehicle_license_plate');

        // Validation state
        const validationState = {
            firstName: false,
            lastName: false,
            email: false,
            phone: false,
            password: false,
            passwordConfirm: false,
            vehicleBrand: false,
            vehicleModel: false,
            vehicleColor: false,
            vehicleLicensePlate: false
        };

        // Icons
        const checkIcon = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>';
        const errorIcon = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>';

        // Update submit button state
        function updateSubmitButton() {
            const allValid = Object.values(validationState).every(v => v);
            submitBtn.disabled = !allValid;
        }

        // Show feedback
        function showFeedback(elementId, isValid, message) {
            const feedback = document.getElementById(elementId + '_feedback');
            if (!feedback) return;

            if (message) {
                feedback.innerHTML = (isValid ? checkIcon : errorIcon) + '<span>' + message + '</span>';
                feedback.className = 'input-feedback ' + (isValid ? 'success' : 'error');
            } else {
                feedback.innerHTML = '';
                feedback.className = 'input-feedback';
            }

            const input = document.getElementById(elementId);
            if (input && message) {
                input.classList.remove('valid', 'invalid');
                input.classList.add(isValid ? 'valid' : 'invalid');
            } else if (input) {
                input.classList.remove('valid', 'invalid');
            }
        }

        // Generic text field validation
        function validateTextField(input, stateKey, minLength = 2) {
            const value = input.value.trim();
            if (value.length === 0) {
                validationState[stateKey] = false;
                showFeedback(input.id, false, '');
            } else if (value.length < minLength) {
                validationState[stateKey] = false;
                showFeedback(input.id, false, 'Minimum ' + minLength + ' caractères');
            } else {
                validationState[stateKey] = true;
                showFeedback(input.id, true, '');
            }
            updateSubmitButton();
        }

        // Validate email
        function validateEmail() {
            const value = email.value.trim();
            const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

            if (value.length === 0) {
                validationState.email = false;
                showFeedback('email', false, '');
            } else if (!emailRegex.test(value)) {
                validationState.email = false;
                showFeedback('email', false, 'Format invalide');
            } else {
                validationState.email = true;
                showFeedback('email', true, '');
            }
            updateSubmitButton();
        }

        // Validate phone
        function validatePhone() {
            const value = phone.value.trim();
            // Moroccan phone format or international
            const phoneRegex = /^(\+?\d{1,3}[-.\s]?)?\d{9,15}$/;

            if (value.length === 0) {
                validationState.phone = false;
                showFeedback('phone', false, '');
            } else if (!phoneRegex.test(value.replace(/\s/g, ''))) {
                validationState.phone = false;
                showFeedback('phone', false, 'Format invalide');
            } else {
                validationState.phone = true;
                showFeedback('phone', true, '');
            }
            updateSubmitButton();
        }

        // Validate password
        function validatePassword() {
            const value = password.value;

            const hasLength = value.length >= 8;
            const hasUppercase = /[A-Z]/.test(value);
            const hasLowercase = /[a-z]/.test(value);
            const hasDigit = /[0-9]/.test(value);

            // Update requirement indicators
            document.getElementById('req-length').classList.toggle('valid', hasLength);
            document.getElementById('req-uppercase').classList.toggle('valid', hasUppercase);
            document.getElementById('req-lowercase').classList.toggle('valid', hasLowercase);
            document.getElementById('req-digit').classList.toggle('valid', hasDigit);

            validationState.password = hasLength && hasUppercase && hasLowercase && hasDigit;

            // Update input style
            if (value.length === 0) {
                password.classList.remove('valid', 'invalid');
            } else {
                password.classList.remove('valid', 'invalid');
                password.classList.add(validationState.password ? 'valid' : 'invalid');
            }

            // Also revalidate confirm password
            validatePasswordConfirm();
            updateSubmitButton();
        }

        // Validate password confirmation
        function validatePasswordConfirm() {
            const value = passwordConfirm.value;
            const passwordValue = password.value;

            if (value.length === 0) {
                validationState.passwordConfirm = false;
                showFeedback('password_confirm', false, '');
            } else if (value !== passwordValue) {
                validationState.passwordConfirm = false;
                showFeedback('password_confirm', false, 'Ne correspond pas');
            } else if (!validationState.password) {
                validationState.passwordConfirm = false;
                showFeedback('password_confirm', false, '');
            } else {
                validationState.passwordConfirm = true;
                showFeedback('password_confirm', true, 'Correspond');
            }
            updateSubmitButton();
        }

        // Toggle password visibility
        function setupPasswordToggle(toggleId, inputId) {
            const toggle = document.getElementById(toggleId);
            const input = document.getElementById(inputId);
            if (!toggle || !input) return;

            toggle.addEventListener('click', function() {
                const eyeOpen = this.querySelector('.eye-open');
                const eyeClosed = this.querySelector('.eye-closed');

                if (input.type === 'password') {
                    input.type = 'text';
                    eyeOpen.style.display = 'none';
                    eyeClosed.style.display = 'block';
                } else {
                    input.type = 'password';
                    eyeOpen.style.display = 'block';
                    eyeClosed.style.display = 'none';
                }
            });
        }

        // Event listeners - Personal info
        firstName.addEventListener('input', () => validateTextField(firstName, 'firstName'));
        firstName.addEventListener('blur', () => validateTextField(firstName, 'firstName'));

        lastName.addEventListener('input', () => validateTextField(lastName, 'lastName'));
        lastName.addEventListener('blur', () => validateTextField(lastName, 'lastName'));

        email.addEventListener('input', validateEmail);
        email.addEventListener('blur', validateEmail);

        phone.addEventListener('input', validatePhone);
        phone.addEventListener('blur', validatePhone);

        password.addEventListener('input', validatePassword);
        password.addEventListener('blur', validatePassword);

        passwordConfirm.addEventListener('input', validatePasswordConfirm);
        passwordConfirm.addEventListener('blur', validatePasswordConfirm);

        // Event listeners - Vehicle info
        vehicleBrand.addEventListener('input', () => validateTextField(vehicleBrand, 'vehicleBrand'));
        vehicleBrand.addEventListener('blur', () => validateTextField(vehicleBrand, 'vehicleBrand'));

        vehicleModel.addEventListener('input', () => validateTextField(vehicleModel, 'vehicleModel'));
        vehicleModel.addEventListener('blur', () => validateTextField(vehicleModel, 'vehicleModel'));

        vehicleColor.addEventListener('input', () => validateTextField(vehicleColor, 'vehicleColor'));
        vehicleColor.addEventListener('blur', () => validateTextField(vehicleColor, 'vehicleColor'));

        vehicleLicensePlate.addEventListener('input', () => validateTextField(vehicleLicensePlate, 'vehicleLicensePlate', 3));
        vehicleLicensePlate.addEventListener('blur', () => validateTextField(vehicleLicensePlate, 'vehicleLicensePlate', 3));

        // Setup password toggles
        setupPasswordToggle('togglePassword', 'password');
        setupPasswordToggle('togglePasswordConfirm', 'password_confirm');

        // Form submit validation
        form.addEventListener('submit', function(e) {
            // Run all validations
            validateTextField(firstName, 'firstName');
            validateTextField(lastName, 'lastName');
            validateEmail();
            validatePhone();
            validatePassword();
            validatePasswordConfirm();
            validateTextField(vehicleBrand, 'vehicleBrand');
            validateTextField(vehicleModel, 'vehicleModel');
            validateTextField(vehicleColor, 'vehicleColor');
            validateTextField(vehicleLicensePlate, 'vehicleLicensePlate', 3);

            // Check if all valid
            const allValid = Object.values(validationState).every(v => v);
            if (!allValid) {
                e.preventDefault();
                // Focus first invalid field
                const fields = [firstName, lastName, email, phone, password, passwordConfirm,
                               vehicleBrand, vehicleModel, vehicleColor, vehicleLicensePlate];
                const keys = Object.keys(validationState);

                for (let i = 0; i < keys.length; i++) {
                    if (!validationState[keys[i]]) {
                        fields[i].focus();
                        break;
                    }
                }
            }
        });

    })();
    </script>
</body>
</html>
