<script>
    // Checklist state
    let checklistValid = <?= json_encode($checklistStatus['is_valid'] ?? false) ?>;
    const checklistConfig = {
        title: <?= json_encode(__('checklist.title')) ?>,
        submitted: <?= json_encode(__('checklist.submitted')) ?>,
        required: <?= json_encode(__('checklist.complete_to_go_online')) ?>,
        allRequired: <?= json_encode(__('checklist.all_required')) ?>,
        error: <?= json_encode(__('error.generic')) ?>
    };

    // Toggle availability - with checklist verification
    document.getElementById('availabilityToggle').addEventListener('change', async function() {
        const isAvailable = this.checked;
        const statusIcon = document.getElementById('statusIcon');
        const statusText = document.getElementById('statusText');
        const statusHint = document.getElementById('statusHint');

        // If trying to go online, check checklist first
        if (isAvailable && !checklistValid) {
            this.checked = false; // Revert toggle
            showChecklistModal();
            return;
        }

        try {
            const response = await ApiService.post('drivers?action=availability', {
                is_available: isAvailable
            });

            if (response.success) {
                // Update icon
                statusIcon.className = 'driver-status-icon ' + (isAvailable ? 'online' : 'offline');
                statusIcon.innerHTML = isAvailable
                    ? '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>'
                    : '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>';

                // Update text
                statusText.textContent = isAvailable
                    ? <?= json_encode(__('driver.online')) ?>
                    : <?= json_encode(__('driver.offline')) ?>;

                // Update hint
                statusHint.textContent = isAvailable
                    ? <?= json_encode(__('driver.accepting_rides')) ?>
                    : <?= json_encode(__('driver.not_accepting')) ?>;

                // Haptic feedback
                if ('vibrate' in navigator) {
                    navigator.vibrate(20);
                }

                // Show toast notification
                if (typeof showToast === 'function') {
                    showToast('success', response.message || <?= json_encode(__('msg.status_changed')) ?>);
                }
            }
        } catch (error) {
            console.error('Error updating availability:', error);
            this.checked = !isAvailable;
            if (typeof showToast === 'function') {
                showToast('error', <?= json_encode(__('error.generic')) ?>);
            }
        }
    });

    // === CHECKLIST MODAL FUNCTIONS ===

    function showChecklistModal() {
        document.getElementById('checklistModal').classList.remove('hidden');
        document.body.style.overflow = 'hidden';
    }

    function hideChecklistModal() {
        document.getElementById('checklistModal').classList.add('hidden');
        document.body.style.overflow = '';
        // Reset form
        document.getElementById('checklistForm').reset();
        document.getElementById('photoPreview').classList.add('hidden');
        document.getElementById('photoPlaceholder').classList.remove('hidden');
    }

    // Cancel button
    document.getElementById('cancelChecklist').addEventListener('click', hideChecklistModal);

    // Photo upload handling
    const photoUploadArea = document.getElementById('photoUploadArea');
    const photoInput = document.getElementById('dashcamPhotoInput');
    const photoPreview = document.getElementById('photoPreview');
    const photoPlaceholder = document.getElementById('photoPlaceholder');
    const photoPreviewImg = document.getElementById('photoPreviewImg');
    const removePhotoBtn = document.getElementById('removePhoto');

    photoUploadArea.addEventListener('click', function(e) {
        if (e.target !== removePhotoBtn && !removePhotoBtn.contains(e.target)) {
            photoInput.click();
        }
    });

    photoInput.addEventListener('change', function(e) {
        const file = e.target.files[0];
        if (file) {
            const reader = new FileReader();
            reader.onload = function(e) {
                photoPreviewImg.src = e.target.result;
                photoPreview.classList.remove('hidden');
                photoPlaceholder.classList.add('hidden');
            };
            reader.readAsDataURL(file);
        }
    });

    removePhotoBtn.addEventListener('click', function(e) {
        e.stopPropagation();
        photoInput.value = '';
        photoPreview.classList.add('hidden');
        photoPlaceholder.classList.remove('hidden');
    });

    // Form submission
    document.getElementById('checklistForm').addEventListener('submit', async function(e) {
        e.preventDefault();

        const submitBtn = document.getElementById('submitChecklist');
        const originalText = submitBtn.textContent;
        submitBtn.disabled = true;
        submitBtn.innerHTML = '<span class="spinner-small"></span>';

        // Build FormData for file upload
        const formData = new FormData(this);

        // Add checklist items as booleans
        const checkboxes = this.querySelectorAll('input[type="checkbox"]');
        checkboxes.forEach(cb => {
            formData.set(cb.name, cb.checked ? '1' : '0');
        });

        try {
            // Use fetch directly for FormData (multipart/form-data)
            const response = await fetch(AppConfig.apiUrl('drivers?action=safety-checklist'), {
                method: 'POST',
                body: formData,
                headers: {
                    'X-CSRF-Token': AppConfig.csrfToken
                }
            });

            const result = await response.json();

            if (result.success) {
                checklistValid = true;
                hideChecklistModal();

                // Show success toast
                if (typeof showToast === 'function') {
                    showToast('success', checklistConfig.submitted);
                }

                // Auto-toggle online after successful checklist
                setTimeout(() => {
                    document.getElementById('availabilityToggle').checked = true;
                    document.getElementById('availabilityToggle').dispatchEvent(new Event('change'));
                }, 500);
            } else {
                throw new Error(result.message || checklistConfig.error);
            }
        } catch (error) {
            console.error('Checklist submission error:', error);
            if (typeof showToast === 'function') {
                showToast('error', error.message || checklistConfig.error);
            }
        } finally {
            submitBtn.disabled = false;
            submitBtn.textContent = originalText;
        }
    });

    // Share trip button
    document.getElementById('shareTrip')?.addEventListener('click', async function() {
        if (navigator.share) {
            try {
                await navigator.share({
                    title: 'TripSalama - Ma position',
                    text: <?= json_encode(__('driver.share_trip_hint')) ?>,
                    url: window.location.href
                });
            } catch (err) {
                console.log('Share cancelled');
            }
        } else {
            if (typeof showToast === 'function') {
                showToast('info', 'Partage non disponible sur cet appareil');
            }
        }
    });
</script>
