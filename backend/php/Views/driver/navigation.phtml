<!-- SOS Recorder Module -->
<script src="<?= asset_url('js/modules/sos-recorder.js') ?>"></script>
<script>
    // SOS Configuration
    const SOSConfig = {
        rideId: <?= (int)$ride['id'] ?>,
        i18n: {
            title: <?= json_encode(__('recording.title')) ?>,
            start: <?= json_encode(__('recording.start')) ?>,
            stop: <?= json_encode(__('recording.stop')) ?>,
            recording: <?= json_encode(__('recording.recording')) ?>,
            uploading: <?= json_encode(__('recording.uploading')) ?>,
            uploaded: <?= json_encode(__('recording.uploaded')) ?>,
            error: <?= json_encode(__('error.generic')) ?>,
            permissionDenied: <?= json_encode(__('recording.permission_denied')) ?>,
            notSupported: <?= json_encode(__('recording.not_supported')) ?>
        }
    };

    // Initialize SOS functionality
    document.addEventListener('DOMContentLoaded', function() {
        const sosButton = document.getElementById('sosButton');
        const sosModal = document.getElementById('sosModal');
        const closeSosBtn = document.getElementById('closeSosModal');
        const startBtn = document.getElementById('startRecordingBtn');
        const stopBtn = document.getElementById('stopRecordingBtn');
        const sosIcon = document.getElementById('sosIcon');
        const sosSubtitle = document.getElementById('sosSubtitle');
        const videoContainer = document.getElementById('sosVideoContainer');
        const videoPreview = document.getElementById('sosVideoPreview');
        const timerEl = document.getElementById('sosTimer');
        const timerText = document.getElementById('sosTimerText');
        const uploadProgress = document.getElementById('sosUploadProgress');
        const uploadFill = document.getElementById('sosUploadFill');
        const uploadText = document.getElementById('sosUploadText');

        // Initialize SOS Recorder
        SOSRecorder.init({
            rideId: SOSConfig.rideId,
            onRecordingStart: function(data) {
                startBtn.classList.add('hidden');
                stopBtn.classList.remove('hidden');
                sosIcon.classList.add('recording');
                sosSubtitle.textContent = SOSConfig.i18n.recording;
                timerEl.classList.remove('hidden');

                // Show video preview if video recording
                if (data.type === 'video') {
                    videoContainer.classList.remove('hidden');
                    videoPreview.srcObject = SOSRecorder.getStream();
                }
            },
            onRecordingStop: function(data) {
                stopBtn.classList.add('hidden');
                sosIcon.classList.remove('recording');
                timerEl.classList.add('hidden');
                videoContainer.classList.add('hidden');
                videoPreview.srcObject = null;

                // Show upload progress
                uploadProgress.classList.remove('hidden');
                sosSubtitle.textContent = SOSConfig.i18n.uploading;
            },
            onRecordingProgress: function(data) {
                const minutes = Math.floor(data.elapsed / 60);
                const seconds = data.elapsed % 60;
                timerText.textContent = String(minutes).padStart(2, '0') + ':' + String(seconds).padStart(2, '0');
            },
            onUploadProgress: function(data) {
                uploadFill.style.width = data.percent + '%';
                uploadText.textContent = SOSConfig.i18n.uploading + ' ' + data.percent + '%';
            },
            onUploadComplete: function(data) {
                uploadProgress.classList.add('hidden');
                sosSubtitle.textContent = SOSConfig.i18n.uploaded;

                // Show toast
                if (typeof Toast !== 'undefined') {
                    Toast.success(SOSConfig.i18n.uploaded);
                }

                // Reset after delay
                setTimeout(resetSOSModal, 2000);
            },
            onError: function(data) {
                console.error('SOS Error:', data);
                if (typeof Toast !== 'undefined') {
                    Toast.error(SOSConfig.i18n.error);
                }
                resetSOSModal();
            }
        });

        // Open SOS Modal
        sosButton.addEventListener('click', async function() {
            // Check if supported
            if (!SOSRecorder.isSupported()) {
                if (typeof Toast !== 'undefined') {
                    Toast.error(SOSConfig.i18n.notSupported);
                }
                return;
            }

            // Check permissions
            const permission = await SOSRecorder.checkPermissions('video');
            if (!permission.granted && permission.reason === 'permission_denied') {
                if (typeof Toast !== 'undefined') {
                    Toast.error(SOSConfig.i18n.permissionDenied);
                }
                return;
            }

            sosModal.classList.remove('hidden');
            document.body.style.overflow = 'hidden';
        });

        // Close SOS Modal
        closeSosBtn.addEventListener('click', function() {
            // Stop recording if in progress
            if (SOSRecorder.getState().isRecording) {
                SOSRecorder.stopRecording();
            }
            closeSosModal();
        });

        // Start Recording
        startBtn.addEventListener('click', async function() {
            const started = await SOSRecorder.startRecording('video');
            if (!started) {
                if (typeof Toast !== 'undefined') {
                    Toast.error(SOSConfig.i18n.error);
                }
            }
        });

        // Stop Recording
        stopBtn.addEventListener('click', function() {
            SOSRecorder.stopRecording();
        });

        function closeSosModal() {
            sosModal.classList.add('hidden');
            document.body.style.overflow = '';
            resetSOSModal();
        }

        function resetSOSModal() {
            startBtn.classList.remove('hidden');
            stopBtn.classList.add('hidden');
            sosIcon.classList.remove('recording');
            sosSubtitle.textContent = SOSConfig.i18n.start;
            timerEl.classList.add('hidden');
            timerText.textContent = '00:00';
            videoContainer.classList.add('hidden');
            uploadProgress.classList.add('hidden');
            uploadFill.style.width = '0%';
            SOSRecorder.cleanup();
        }
    });
</script>
