    <style>
        /* SOS Button Floating - Modern Typography */
        .sos-fab {
            position: fixed;
            bottom: calc(var(--nav-height, 55px) + var(--space-8, 21px) + var(--space-4, 8px));
            right: var(--space-4, 8px);
            width: 55px;
            height: 55px;
            background: linear-gradient(135deg, #dc2626 0%, #b91c1c 100%);
            border: none;
            border-radius: 50%;
            color: #ffffff;
            font-family: var(--font-family, 'Inter', -apple-system, BlinkMacSystemFont, sans-serif);
            font-size: 11px;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            cursor: pointer;
            box-shadow: 0 4px 21px rgba(220, 38, 38, 0.4);
            z-index: 1000;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: transform 0.2s ease, box-shadow 0.2s ease;
            overflow: hidden;
        }

        .sos-fab:hover,
        .sos-fab:active {
            transform: scale(1.08);
            box-shadow: 0 8px 34px rgba(220, 38, 38, 0.5);
        }

        .sos-fab:focus {
            outline: 3px solid rgba(220, 38, 38, 0.5);
            outline-offset: 2px;
        }

        /* SOS Modal */
        .sos-modal {
            position: fixed;
            inset: 0;
            background: rgba(0, 0, 0, 0.8);
            z-index: 10000;
            display: none;
            align-items: center;
            justify-content: center;
            padding: 8px;
        }

        .sos-modal.active {
            display: flex;
        }

        .sos-modal-content {
            background: #ffffff;
            border-radius: 21px;
            padding: 34px;
            max-width: 320px;
            width: 100%;
            text-align: center;
        }

        .sos-modal-icon {
            width: 55px;
            height: 55px;
            background: #dc2626;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 13px;
        }

        .sos-modal-icon svg {
            width: 34px;
            height: 34px;
            color: #ffffff;
        }

        .sos-modal-title {
            font-size: 21px;
            font-weight: 700;
            color: #000000;
            margin-bottom: 8px;
        }

        .sos-modal-text {
            font-size: 13px;
            color: #6b7280;
            margin-bottom: 21px;
        }

        .sos-modal-actions {
            display: flex;
            flex-direction: column;
            gap: 13px;
        }

        .sos-btn-emergency {
            width: 100%;
            padding: 13px;
            background: linear-gradient(135deg, #dc2626 0%, #b91c1c 100%);
            color: #ffffff;
            border: none;
            border-radius: 13px;
            font-family: var(--font-family, 'Inter', -apple-system, BlinkMacSystemFont, sans-serif);
            font-size: var(--text-base, 16px);
            font-weight: 700;
            cursor: pointer;
            min-height: 55px;
            overflow: hidden;
            transition: transform 0.2s ease, box-shadow 0.2s ease;
        }

        .sos-btn-emergency:hover {
            transform: scale(1.02);
            box-shadow: 0 4px 21px rgba(220, 38, 38, 0.4);
        }

        .sos-btn-cancel {
            width: 100%;
            padding: 13px;
            background: var(--uber-gray-100, #f3f4f6);
            color: #000000;
            border: none;
            border-radius: 13px;
            font-family: var(--font-family, 'Inter', -apple-system, BlinkMacSystemFont, sans-serif);
            font-size: var(--text-base, 16px);
            font-weight: 600;
            cursor: pointer;
            min-height: 55px;
            overflow: hidden;
            transition: background 0.2s ease;
        }

        .sos-btn-cancel:hover {
            background: var(--uber-gray-200, #e5e7eb);
        }

        @keyframes sosPulse {
            0%, 100% { box-shadow: 0 4px 21px rgba(220, 38, 38, 0.4); }
            50% { box-shadow: 0 4px 34px rgba(220, 38, 38, 0.7); }
        }

        .sos-fab.pulsing {
            animation: sosPulse 1.5s ease-in-out infinite;
        }
