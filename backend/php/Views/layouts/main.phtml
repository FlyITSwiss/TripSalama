    <?php if (is_authenticated() && has_role('passenger')): ?>
    <!-- SOS Button Handler -->
    <script>
    (function() {
        'use strict';
        const sosButton = document.getElementById('sosButton');
        const sosModal = document.getElementById('sosModal');
        const sosConfirmBtn = document.getElementById('sosConfirmBtn');
        const sosCancelBtn = document.getElementById('sosCancelBtn');
        if (!sosButton || !sosModal) return;

        // Ouvrir le modal SOS
        sosButton.addEventListener('click', function() {
            sosModal.classList.add('active');
            sosButton.classList.add('pulsing');
        });

        // Annuler
        sosCancelBtn.addEventListener('click', function() {
            sosModal.classList.remove('active');
            sosButton.classList.remove('pulsing');
        });

        // Fermer en cliquant en dehors
        sosModal.addEventListener('click', function(e) {
            if (e.target === sosModal) {
                sosModal.classList.remove('active');
                sosButton.classList.remove('pulsing');
            }
        });

        // Confirmer l'alerte SOS
        sosConfirmBtn.addEventListener('click', async function() {
            sosConfirmBtn.disabled = true;
            sosConfirmBtn.textContent = '...';
            try {
                let position = null;
                try {
                    position = await new Promise((resolve, reject) => {
                        navigator.geolocation.getCurrentPosition(resolve, reject, {
                            enableHighAccuracy: true,
                            timeout: 5000
                        });
                    });
                } catch (geoError) {
                    console.warn('Géolocalisation non disponible');
                }

                const response = await fetch(window.AppConfig ? window.AppConfig.basePath + '/api/sos.php' : '/api/sos.php', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]')?.content || ''
                    },
                    body: JSON.stringify({
                        action: 'trigger',
                        alert_type: 'sos',
                        latitude: position?.coords?.latitude || null,
                        longitude: position?.coords?.longitude || null,
                        message: <?= json_encode(__('sos.alert_sent')) ?>
                    })
                });

                const data = await response.json();
                if (data.success) {
                    sosModal.classList.remove('active');
                    sosButton.classList.remove('pulsing');
                    if (typeof showToast === 'function') {
                        showToast('success', <?= json_encode(__('sos.alert_sent')) ?>);
                    } else {
                        alert(<?= json_encode(__('sos.alert_sent')) ?>);
                    }
                } else {
                    throw new Error(data.message || <?= json_encode(__('error.generic')) ?>);
                }
            } catch (error) {
                console.error('SOS Error:', error);
                if (typeof showToast === 'function') {
                    showToast('error', <?= json_encode(__('error.generic')) ?>);
                } else {
                    alert(<?= json_encode(__('error.generic')) ?>);
                }
            } finally {
                sosConfirmBtn.disabled = false;
                sosConfirmBtn.textContent = <?= json_encode(__('sos.call_emergency')) ?>;
            }
        });

        // Fermer avec Escape
        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape' && sosModal.classList.contains('active')) {
                sosModal.classList.remove('active');
                sosButton.classList.remove('pulsing');
            }
        });
    })();
    </script>
