<!-- Leaflet CSS/JS -->
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

<script>
(function() {
    'use strict';

    // Configuration
    const config = {
        defaultCenter: [33.5731, -7.5898], // Casablanca
        defaultZoom: 15,
        nominatimUrl: 'https://nominatim.openstreetmap.org',
        apiUrl: typeof AppConfig !== 'undefined' ? AppConfig.apiPath : '/api',
        csrfToken: typeof AppConfig !== 'undefined' ? AppConfig.csrfToken : ''
    };

    // i18n
    const i18n = {
        addHome: <?= json_encode(__('address.add_home')) ?>,
        addWork: <?= json_encode(__('address.add_work')) ?>,
        editHome: <?= json_encode(__('address.edit_home')) ?>,
        editWork: <?= json_encode(__('address.edit_work')) ?>,
        savedSuccess: <?= json_encode(__('address.saved_success')) ?>,
        saveError: <?= json_encode(__('address.save_error')) ?>,
        noResults: <?= json_encode(__('address.no_results')) ?>,
        detecting: <?= json_encode(__('address.detecting_location')) ?>
    };

    // State
    let addressMap = null;
    let addressMarker = null;
    let currentType = null;
    let selectedAddress = null;
    let selectedLat = null;
    let selectedLng = null;
    let searchTimeout = null;

    // DOM Elements
    const modal = document.getElementById('addressModal');
    const modalTitle = document.getElementById('addressModalTitle');
    const closeBtn = document.getElementById('addressModalClose');
    const searchInput = document.getElementById('addressSearchInput');
    const suggestions = document.getElementById('addressSuggestions');
    const useLocationBtn = document.getElementById('addressUseLocation');
    const selectedDiv = document.getElementById('addressSelected');
    const selectedText = document.getElementById('addressSelectedText');
    const saveBtn = document.getElementById('addressSaveBtn');
    const savedPlaces = document.querySelectorAll('.saved-place');

    // Open modal
    function openModal(type, existingAddress, existingLat, existingLng) {
        currentType = type;
        const hasAddress = existingAddress && existingAddress.trim() !== '';

        // Set title
        if (type === 'home') {
            modalTitle.textContent = hasAddress ? i18n.editHome : i18n.addHome;
        } else {
            modalTitle.textContent = hasAddress ? i18n.editWork : i18n.addWork;
        }

        // Reset state
        searchInput.value = '';
        suggestions.classList.remove('active');
        suggestions.innerHTML = '';
        selectedDiv.classList.remove('active');
        saveBtn.disabled = true;
        selectedAddress = null;
        selectedLat = null;
        selectedLng = null;

        // Show modal
        modal.classList.add('active');
        document.body.style.overflow = 'hidden';

        // Initialize map after modal is visible
        setTimeout(() => {
            initMap(existingLat, existingLng, existingAddress);
        }, 100);
    }

    // Close modal
    function closeModal() {
        modal.classList.remove('active');
        document.body.style.overflow = '';

        // Clean up map
        if (addressMap) {
            addressMap.remove();
            addressMap = null;
        }
    }

    // Initialize map
    function initMap(lat, lng, address) {
        const mapContainer = document.getElementById('addressMap');
        if (!mapContainer) return;

        // Clear existing map
        if (addressMap) {
            addressMap.remove();
        }

        const centerLat = lat && !isNaN(lat) ? parseFloat(lat) : config.defaultCenter[0];
        const centerLng = lng && !isNaN(lng) ? parseFloat(lng) : config.defaultCenter[1];

        addressMap = L.map('addressMap', {
            zoomControl: false
        }).setView([centerLat, centerLng], config.defaultZoom);

        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            maxZoom: 19
        }).addTo(addressMap);

        // Add zoom control to top right
        L.control.zoom({ position: 'topright' }).addTo(addressMap);

        // If there's an existing address, add marker
        if (lat && lng && address) {
            setMarker(centerLat, centerLng, address);
        }

        // Click on map to place marker
        addressMap.on('click', function(e) {
            reverseGeocode(e.latlng.lat, e.latlng.lng);
        });
    }

    // Set marker on map
    function setMarker(lat, lng, address) {
        if (!addressMap) return;

        if (addressMarker) {
            addressMarker.remove();
        }

        addressMarker = L.marker([lat, lng], {
            draggable: true
        }).addTo(addressMap);

        // Update on drag
        addressMarker.on('dragend', function(e) {
            const pos = e.target.getLatLng();
            reverseGeocode(pos.lat, pos.lng);
        });

        // Update state
        selectedLat = lat;
        selectedLng = lng;
        selectedAddress = address;

        // Update UI
        selectedText.textContent = address;
        selectedDiv.classList.add('active');
        saveBtn.disabled = false;

        // Center map
        addressMap.setView([lat, lng], config.defaultZoom);
    }

    // Search addresses
    async function searchAddresses(query) {
        if (!query || query.length < 3) {
            suggestions.classList.remove('active');
            return;
        }

        try {
            const response = await fetch(
                `${config.nominatimUrl}/search?format=json&q=${encodeURIComponent(query)}&limit=5&addressdetails=1`
            );
            const results = await response.json();

            if (results.length === 0) {
                suggestions.innerHTML = `<div class="address-suggestion"><span class="address-suggestion-text">${i18n.noResults}</span></div>`;
            } else {
                suggestions.innerHTML = results.map(r => `
                    <button type="button" class="address-suggestion" data-lat="${r.lat}" data-lng="${r.lon}" data-address="${r.display_name}">
                        <div class="address-suggestion-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <circle cx="12" cy="10" r="3"/>
                                <path d="M12 21.7C17.3 17 20 13 20 10a8 8 0 1 0-16 0c0 3 2.7 7 8 11.7z"/>
                            </svg>
                        </div>
                        <span class="address-suggestion-text">${r.display_name}</span>
                    </button>
                `).join('');
            }

            suggestions.classList.add('active');
        } catch (error) {
            console.error('Search error:', error);
        }
    }

    // Reverse geocode
    async function reverseGeocode(lat, lng) {
        try {
            const response = await fetch(
                `${config.nominatimUrl}/reverse?format=json&lat=${lat}&lon=${lng}&addressdetails=1`
            );
            const result = await response.json();

            if (result && result.display_name) {
                setMarker(lat, lng, result.display_name);
            }
        } catch (error) {
            console.error('Reverse geocode error:', error);
        }
    }

    // Get current location
    function getCurrentLocation() {
        if (!navigator.geolocation) {
            console.error('Geolocation not supported');
            return;
        }

        useLocationBtn.querySelector('span').textContent = i18n.detecting;

        navigator.geolocation.getCurrentPosition(
            (position) => {
                reverseGeocode(position.coords.latitude, position.coords.longitude);
                useLocationBtn.querySelector('span').textContent = <?= json_encode(__('address.use_current_location')) ?>;
            },
            (error) => {
                console.error('Geolocation error:', error);
                useLocationBtn.querySelector('span').textContent = <?= json_encode(__('address.use_current_location')) ?>;
            },
            { enableHighAccuracy: true, timeout: 10000 }
        );
    }

    // Save address
    async function saveAddress() {
        if (!selectedAddress || !selectedLat || !selectedLng || !currentType) {
            return;
        }

        saveBtn.classList.add('loading');
        saveBtn.disabled = true;

        try {
            const formData = new FormData();
            formData.append('type', currentType);
            formData.append('address', selectedAddress);
            formData.append('lat', selectedLat);
            formData.append('lng', selectedLng);

            const response = await fetch(`${config.apiUrl}/user.php?action=save-address`, {
                method: 'POST',
                headers: {
                    'X-CSRF-Token': config.csrfToken
                },
                body: formData
            });

            const result = await response.json();

            if (result.success) {
                // Update the saved place button
                const savedPlace = document.querySelector(`.saved-place[data-type="${currentType}"]`);
                if (savedPlace) {
                    savedPlace.dataset.action = 'use';
                    savedPlace.dataset.address = selectedAddress;
                    savedPlace.dataset.lat = selectedLat;
                    savedPlace.dataset.lng = selectedLng;

                    const addressEl = savedPlace.querySelector('.saved-place-address');
                    const addEl = savedPlace.querySelector('.saved-place-add');

                    if (addEl) {
                        addEl.classList.add('saved-place-address');
                        addEl.classList.remove('saved-place-add');
                        addEl.textContent = selectedAddress;
                    } else if (addressEl) {
                        addressEl.textContent = selectedAddress;
                    }
                }

                // Show success notification
                if (typeof showToast === 'function') {
                    showToast('success', i18n.savedSuccess);
                }

                closeModal();
            } else {
                throw new Error(result.message || i18n.saveError);
            }
        } catch (error) {
            console.error('Save error:', error);
            if (typeof showToast === 'function') {
                showToast('error', i18n.saveError);
            }
        } finally {
            saveBtn.classList.remove('loading');
            saveBtn.disabled = false;
        }
    }

    // Event listeners
    savedPlaces.forEach(btn => {
        btn.addEventListener('click', function(e) {
            e.preventDefault();
            const type = this.dataset.type;
            const action = this.dataset.action;
            const address = this.dataset.address;
            const lat = this.dataset.lat;
            const lng = this.dataset.lng;

            if (action === 'use' && address) {
                // Redirect to booking with destination
                window.location.href = `${typeof base_url === 'function' ? base_url('passenger/book') : '/passenger/book'}?dest=${type}`;
            } else {
                // Open modal to add/edit address
                openModal(type, address, lat, lng);
            }
        });
    });

    closeBtn.addEventListener('click', closeModal);

    modal.addEventListener('click', function(e) {
        if (e.target === modal) {
            closeModal();
        }
    });

    searchInput.addEventListener('input', function() {
        clearTimeout(searchTimeout);
        searchTimeout = setTimeout(() => {
            searchAddresses(this.value);
        }, 300);
    });

    suggestions.addEventListener('click', function(e) {
        const suggestion = e.target.closest('.address-suggestion');
        if (suggestion && suggestion.dataset.lat) {
            const lat = parseFloat(suggestion.dataset.lat);
            const lng = parseFloat(suggestion.dataset.lng);
            const address = suggestion.dataset.address;

            setMarker(lat, lng, address);
            searchInput.value = address;
            suggestions.classList.remove('active');
        }
    });

    useLocationBtn.addEventListener('click', getCurrentLocation);

    saveBtn.addEventListener('click', saveAddress);

    // Close on escape
    document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape' && modal.classList.contains('active')) {
            closeModal();
        }
    });
})();
</script>
