<script>
document.addEventListener('DOMContentLoaded', function() {
    const toast = document.getElementById('toast');

    function showToast(message, type = 'success') {
        toast.textContent = message;
        toast.className = 'toast ' + type + ' show';
        setTimeout(() => {
            toast.classList.remove('show');
        }, 3000);
    }

    async function apiCall(action, data) {
        const formData = new FormData();
        formData.append('csrf_token', '<?= csrf_token() ?>');
        for (const key in data) {
            formData.append(key, data[key]);
        }

        const response = await fetch('<?= base_url("api/admin") ?>?action=' + action, {
            method: 'POST',
            body: formData
        });

        return response.json();
    }

    // Toggle country active
    document.querySelectorAll('.toggle-country-active').forEach(toggle => {
        toggle.addEventListener('change', async function() {
            const countryCode = this.dataset.country;
            const active = this.checked;

            try {
                const result = await apiCall('toggle-country', {
                    country_code: countryCode,
                    enabled: active ? '1' : '0'
                });

                if (result.success) {
                    showToast(result.message, 'success');
                    const card = this.closest('.country-card');
                    card.classList.toggle('inactive', !active);
                } else {
                    this.checked = !active; // Revert
                    showToast(result.message, 'error');
                }
            } catch (e) {
                this.checked = !active;
                showToast('<?= __("error.network") ?>', 'error');
            }
        });
    });

    // Toggle prayer times
    document.querySelectorAll('.toggle-prayer').forEach(toggle => {
        toggle.addEventListener('change', async function() {
            const countryCode = this.dataset.country;
            const enabled = this.checked;

            try {
                const result = await apiCall('toggle-prayer-times', {
                    country_code: countryCode,
                    enabled: enabled ? '1' : '0'
                });

                if (result.success) {
                    showToast(result.message, 'success');
                } else {
                    this.checked = !enabled;
                    showToast(result.message, 'error');
                }
            } catch (e) {
                this.checked = !enabled;
                showToast('<?= __("error.network") ?>', 'error');
            }
        });
    });

    // Toggle arabic
    document.querySelectorAll('.toggle-arabic').forEach(toggle => {
        toggle.addEventListener('change', async function() {
            const countryCode = this.dataset.country;
            const enabled = this.checked;

            try {
                const result = await apiCall('toggle-arabic', {
                    country_code: countryCode,
                    enabled: enabled ? '1' : '0'
                });

                if (result.success) {
                    showToast(result.message, 'success');
                } else {
                    this.checked = !enabled;
                    showToast(result.message, 'error');
                }
            } catch (e) {
                this.checked = !enabled;
                showToast('<?= __("error.network") ?>', 'error');
            }
        });
    });

    // Set default country
    document.querySelectorAll('.btn-set-default').forEach(btn => {
        btn.addEventListener('click', async function() {
            if (this.disabled) return;

            const countryCode = this.dataset.country;

            try {
                const result = await apiCall('set-default-country', {
                    country_code: countryCode
                });

                if (result.success) {
                    showToast(result.message, 'success');
                    // Reload page to update UI
                    setTimeout(() => location.reload(), 1000);
                } else {
                    showToast(result.message, 'error');
                }
            } catch (e) {
                showToast('<?= __("error.network") ?>', 'error');
            }
        });
    });
});
</script>
