    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
}

.admin-header { animation: fadeInUp 0.4s ease-out; }
.stats-grid { animation: fadeInUp 0.4s ease-out 0.05s backwards; }
