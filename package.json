{
  "name": "tripsalama",
  "version": "1.0.0",
  "description": "VTC app for women - Safe rides by women, for women",
  "main": "index.js",
  "directories": {
    "test": "tests"
  },
  "scripts": {
    "postinstall": "node scripts/patch-ios-dependencies.js",
    "dev": "node scripts/live-reload.js",
    "dev:mobile": "node scripts/live-reload.js",
    "lint": "eslint public/assets/js --ext .js",
    "lint:fix": "eslint public/assets/js --ext .js --fix",
    "test": "node tests/puppeteer/smoke-tests.js",
    "test:visual": "node tests/puppeteer/smoke-tests.js --visual",
    "test:security": "node tests/puppeteer/test-security-audit-fixes.js",
    "validate:playstore": "node scripts/validate-play-store.js",
    "verify:apk": "node scripts/verify-apk-deployment.js",
    "cap:sync": "npx cap sync",
    "cap:open:ios": "npx cap open ios",
    "cap:open:android": "npx cap open android",
    "build:mobile": "npm run cap:sync && echo 'Ready for native build'",
    "build:apk": "bash scripts/build-apk.sh",
    "build:icons": "node scripts/generate-android-icons.js",
    "build:assets": "node scripts/build-assets.js",
    "build:css": "node scripts/build-assets.js --css-only",
    "build:js": "node scripts/build-assets.js --js-only",
    "build:watch": "node scripts/build-assets.js --watch",
    "android:debug": "cd android && ./gradlew assembleDebug",
    "android:release": "cd android && ./gradlew assembleRelease",
    "android:build": "npm run cap:sync && npm run build:icons && npm run android:debug",
    "android:install": "cd android && ./gradlew installDebug",
    "prebuild": "npm run cap:sync && npm run build:icons"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/FlyITSwiss/TripSalama.git"
  },
  "keywords": [
    "vtc",
    "rideshare",
    "women-safety",
    "capacitor",
    "mobile"
  ],
  "author": "Stabilis IT",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/FlyITSwiss/TripSalama/issues"
  },
  "homepage": "https://github.com/FlyITSwiss/TripSalama#readme",
  "dependencies": {
    "@capacitor-community/background-geolocation": "^1.2.26",
    "@capacitor/android": "^8.1.0",
    "@capacitor/app": "^8.0.1",
    "@capacitor/camera": "^8.0.1",
    "@capacitor/core": "^8.1.0",
    "@capacitor/geolocation": "^8.1.0",
    "@capacitor/haptics": "^8.0.0",
    "@capacitor/ios": "^8.1.0",
    "@capacitor/keyboard": "^8.0.0",
    "@capacitor/network": "^8.0.1",
    "@capacitor/preferences": "^8.0.1",
    "@capacitor/push-notifications": "^8.0.1",
    "@capacitor/share": "^8.0.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.1"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.1.0",
    "@playwright/test": "^1.58.2",
    "appium": "^3.2.0",
    "chokidar": "^3.6.0",
    "chromedriver": "^109.0.0",
    "clean-css": "^5.3.3",
    "eslint": "^10.0.1",
    "eslint-plugin-security": "^4.0.0",
    "puppeteer": "^24.37.4",
    "sharp": "^0.34.5",
    "terser": "^5.46.0",
    "webdriverio": "^9.24.0",
    "ws": "^8.19.0"
  }
}
