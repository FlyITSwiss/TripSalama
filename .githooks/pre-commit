#!/bin/bash
###############################################################################
# @file /.githooks/pre-commit
# @description Hook pre-commit STRICT pour TripSalama
#
# Validations automatiques:
# 1. Validation MVC (SQL dans Views/Controllers = ERREUR BLOQUANTE)
# 2. Validation CSS Design System (styles inline = WARNING)
# 3. Validation Paths (paths hardcodes = ERREUR BLOQUANTE)
# 4. Validation i18n (FR/EN sync + accents francais)
# 5. Protection uploads (JAMAIS supprimer les fichiers utilisateur)
# 6. Validation secrets (pas de credentials commites)
# 7. Validation CSRF (tous les endpoints POST doivent verifier CSRF)
#
# Installation:
#   git config core.hooksPath .githooks
#   chmod +x .githooks/pre-commit
#
# Desactiver temporairement:
#   git commit --no-verify
#
# @version 1.0.0
# @date 2026-03
###############################################################################

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(dirname "$SCRIPT_DIR")"

# Couleurs
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
DIM='\033[2m'
BOLD='\033[1m'
NC='\033[0m'

# Timer
START_TIME=$(date +%s 2>/dev/null || echo "0")

echo ""
echo -e "${CYAN}+===================================================================${NC}"
echo -e "${CYAN}|          TRIPSALAMA - PRE-COMMIT STRICT v1.0                    ${NC}"
echo -e "${CYAN}+===================================================================${NC}"
echo ""

ERRORS=0
WARNINGS=0

# ============================================================================
# 1. VERIFICATION SYNTAXE PHP
# ============================================================================
check_php_syntax() {
    local PHP_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.php$|\.phtml$' || true)

    if [ -z "$PHP_FILES" ]; then
        return 0
    fi

    echo -e "${BLUE}[1/7] Verification syntaxe PHP...${NC}"

    # Check if PHP is available
    if ! command -v php &> /dev/null; then
        echo -e "${YELLOW}   PHP non trouve dans PATH - skip syntaxe check${NC}"
        echo -e "${DIM}   (La validation syntaxe PHP sera faite par GitHub Actions)${NC}"
        return 0
    fi

    local errors=0

    while IFS= read -r file; do
        if [ -f "$file" ]; then
            if ! php -l "$file" > /dev/null 2>&1; then
                echo -e "${RED}   ERREUR PHP: $file${NC}"
                php -l "$file" 2>&1 | head -3
                errors=$((errors + 1))
            fi
        fi
    done <<< "$PHP_FILES"

    if [ $errors -gt 0 ]; then
        echo -e "${RED}   $errors erreur(s) de syntaxe PHP${NC}"
        ERRORS=$((ERRORS + errors))
        return 1
    fi

    echo -e "${GREEN}   Syntaxe PHP OK${NC}"
    return 0
}

# ============================================================================
# 2. VALIDATION MVC - PAS DE SQL DANS CONTROLLERS/VIEWS
# ============================================================================
check_mvc() {
    local PHP_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.php$|\.phtml$' || true)

    if [ -z "$PHP_FILES" ]; then
        return 0
    fi

    echo -e "${BLUE}[2/7] Validation MVC...${NC}"
    local errors=0

    while IFS= read -r file; do
        # Verifier Controllers - pas de SQL direct
        if echo "$file" | grep -q "Controllers/"; then
            if git diff --cached "$file" 2>/dev/null | grep -E "^\+" | grep -vE "^\+\+\+" | grep -iE "(->query|->prepare|->execute|SELECT\s|INSERT\s|UPDATE\s|DELETE\s)" > /dev/null 2>&1; then
                echo -e "${RED}   MVC VIOLATION: $file (SQL dans Controller)${NC}"
                echo -e "${YELLOW}   -> Utiliser le Model correspondant${NC}"
                errors=$((errors + 1))
            fi
        fi

        # Verifier Views - pas de SQL ni logique metier
        if echo "$file" | grep -q "Views/"; then
            if git diff --cached "$file" 2>/dev/null | grep -E "^\+" | grep -vE "^\+\+\+" | grep -iE "(->query|->prepare|new.*Service|new.*Controller)" > /dev/null 2>&1; then
                echo -e "${RED}   MVC VIOLATION: $file (SQL/Service dans View)${NC}"
                echo -e "${YELLOW}   -> Passer les donnees depuis le Controller${NC}"
                errors=$((errors + 1))
            fi
        fi
    done <<< "$PHP_FILES"

    if [ $errors -gt 0 ]; then
        ERRORS=$((ERRORS + errors))
        return 1
    fi

    echo -e "${GREEN}   MVC OK${NC}"
    return 0
}

# ============================================================================
# 3. VALIDATION PATHS - PAS DE CHEMINS HARDCODES
# ============================================================================
check_paths() {
    local FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(php|phtml|js)$' || true)

    if [ -z "$FILES" ]; then
        return 0
    fi

    echo -e "${BLUE}[3/7] Validation Paths...${NC}"
    local errors=0

    while IFS= read -r file; do
        # Ignorer config, helpers, et validators (ils contiennent les patterns a detecter)
        if [[ "$file" == *"config/"* ]] || [[ "$file" == *"Helpers/"* ]] || [[ "$file" == *"validators/"* ]] || [[ "$file" == *".githooks/"* ]]; then
            continue
        fi

        # Detecter paths hardcodes
        local BAD_PATHS=$(git diff --cached "$file" 2>/dev/null | grep -E "^\+" | grep -vE "^\+\+\+" | grep -oE "(/var/www/tripsalama|/home/.*tripsalama|C:\\\\.*TripSalama)" || true)
        if [ -n "$BAD_PATHS" ]; then
            echo -e "${RED}   PATH HARDCODE: $file${NC}"
            echo -e "${YELLOW}   -> Utiliser PathHelper ou config('paths.*')${NC}"
            errors=$((errors + 1))
        fi

        # Detecter URLs hardcodees
        local BAD_URLS=$(git diff --cached "$file" 2>/dev/null | grep -E "^\+" | grep -vE "^\+\+\+" | grep -oE 'href="/[a-z]' || true)
        if [ -n "$BAD_URLS" ]; then
            # Ignorer les ancres (#)
            BAD_URLS=$(echo "$BAD_URLS" | grep -v 'href="/#' || true)
            if [ -n "$BAD_URLS" ]; then
                echo -e "${YELLOW}   URL HARDCODEE: $file${NC}"
                echo -e "${DIM}   -> Utiliser base_url() en PHP ou AppConfig.baseUrl() en JS${NC}"
                WARNINGS=$((WARNINGS + 1))
            fi
        fi
    done <<< "$FILES"

    if [ $errors -gt 0 ]; then
        ERRORS=$((ERRORS + errors))
        return 1
    fi

    echo -e "${GREEN}   Paths OK${NC}"
    return 0
}

# ============================================================================
# 4. VALIDATION i18n - ACCENTS + SYNC FR/EN
# ============================================================================
check_i18n() {
    local FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(php|phtml)$' || true)

    if [ -z "$FILES" ]; then
        return 0
    fi

    echo -e "${BLUE}[4/7] Validation i18n...${NC}"
    local errors=0

    # Verifier textes francais hardcodes
    while IFS= read -r file; do
        # Detecter textes FR hardcodes courants
        local HARDCODED=$(git diff --cached "$file" 2>/dev/null | grep -E "^\+" | grep -vE "^\+\+\+" | grep -oE "'(Erreur|Veuillez|Succes|Chargement|Aucun|Connexion|Deconnexion)'" || true)
        if [ -n "$HARDCODED" ]; then
            echo -e "${YELLOW}   i18n: $file - Texte FR hardcode detecte${NC}"
            echo -e "${DIM}   -> Utiliser __('clé') pour l'internationalisation${NC}"
            WARNINGS=$((WARNINGS + 1))
        fi

        # Verifier accents manquants
        local MISSING_ACCENTS=$(git diff --cached "$file" 2>/dev/null | grep -E "^\+" | grep -vE "^\+\+\+" | grep -oE "'(mise a jour|cree|reussi|echoue|termine|selectionnez)'" || true)
        if [ -n "$MISSING_ACCENTS" ]; then
            echo -e "${RED}   ACCENTS: $file - Accents FR manquants${NC}"
            echo -e "${YELLOW}   -> 'mise a jour' doit etre 'mise a jour', 'cree' doit etre 'cree'${NC}"
            errors=$((errors + 1))
        fi
    done <<< "$FILES"

    # Verifier sync fr.php / en.php si modifies
    local LANG_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E "lang/(fr|en)\.php$" || true)
    if [ -n "$LANG_FILES" ]; then
        local FR_COUNT=$(grep -c "=>" "$PROJECT_ROOT/backend/php/lang/fr.php" 2>/dev/null || echo "0")
        local EN_COUNT=$(grep -c "=>" "$PROJECT_ROOT/backend/php/lang/en.php" 2>/dev/null || echo "0")

        if [ "$FR_COUNT" != "$EN_COUNT" ]; then
            echo -e "${YELLOW}   i18n DESYNC: fr.php ($FR_COUNT) != en.php ($EN_COUNT)${NC}"
            WARNINGS=$((WARNINGS + 1))
        fi
    fi

    if [ $errors -gt 0 ]; then
        ERRORS=$((ERRORS + errors))
        return 1
    fi

    echo -e "${GREEN}   i18n OK${NC}"
    return 0
}

# ============================================================================
# 5. PROTECTION UPLOADS - JAMAIS SUPPRIMER
# ============================================================================
check_uploads() {
    echo -e "${BLUE}[5/7] Protection uploads...${NC}"
    local errors=0

    # Verifier suppression de fichiers uploades
    local DELETED=$(git diff --cached --name-only --diff-filter=D | grep -E "^public/uploads/|^storage/uploads/" || true)
    if [ -n "$DELETED" ]; then
        # Autoriser .gitkeep
        DELETED=$(echo "$DELETED" | grep -v "\.gitkeep" || true)
        if [ -n "$DELETED" ]; then
            echo -e "${RED}   UPLOADS: Suppression de fichiers utilisateur bloquee!${NC}"
            echo "$DELETED" | head -5
            errors=$((errors + 1))
        fi
    fi

    # Verifier commandes dangereuses
    local SH_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(sh|yml|yaml)$' || true)
    if [ -n "$SH_FILES" ]; then
        while IFS= read -r file; do
            local DANGER=$(git diff --cached "$file" 2>/dev/null | grep -E "^\+" | grep -vE "^\+\s*#" | grep -iE "docker.*(down\s+-v|volume\s+rm|volume\s+prune)" || true)
            if [ -n "$DANGER" ]; then
                echo -e "${RED}   DANGER: $file - Commande Docker destructrice${NC}"
                echo -e "${YELLOW}   -> docker-compose down -v DETRUIT les uploads${NC}"
                errors=$((errors + 1))
            fi
        done <<< "$SH_FILES"
    fi

    if [ $errors -gt 0 ]; then
        ERRORS=$((ERRORS + errors))
        return 1
    fi

    echo -e "${GREEN}   Uploads proteges${NC}"
    return 0
}

# ============================================================================
# 6. VALIDATION SECRETS - PAS DE CREDENTIALS COMMITES
# ============================================================================
check_secrets() {
    local FILES=$(git diff --cached --name-only --diff-filter=ACM || true)

    if [ -z "$FILES" ]; then
        return 0
    fi

    echo -e "${BLUE}[6/7] Scan secrets...${NC}"
    local errors=0

    while IFS= read -r file; do
        # Ignorer .env.example, tests, et validators (ils contiennent les patterns a detecter)
        if [[ "$file" == *".env.example"* ]] || [[ "$file" == *"tests/"* ]] || [[ "$file" == *"validators/"* ]]; then
            continue
        fi

        # Detecter patterns sensibles
        local SECRETS=$(git diff --cached "$file" 2>/dev/null | grep -E "^\+" | grep -vE "^\+\+\+" | grep -iE "(password\s*=\s*['\"][^'\"]{8,}|api_key\s*=\s*['\"][^'\"]+|secret\s*=\s*['\"][^'\"]+|TWILIO_AUTH_TOKEN|STRIPE_SECRET)" | grep -v "process\.env" | grep -v "\$_ENV" | grep -v "getenv" || true)
        if [ -n "$SECRETS" ]; then
            echo -e "${RED}   SECRET: $file - Credential potentiel detecte${NC}"
            echo -e "${YELLOW}   -> Utiliser variables d'environnement${NC}"
            errors=$((errors + 1))
        fi
    done <<< "$FILES"

    # Verifier .env n'est pas commite
    if echo "$FILES" | grep -qE "^\.env$"; then
        echo -e "${RED}   SECRET: .env ne doit JAMAIS etre commite!${NC}"
        errors=$((errors + 1))
    fi

    if [ $errors -gt 0 ]; then
        ERRORS=$((ERRORS + errors))
        return 1
    fi

    echo -e "${GREEN}   Secrets OK${NC}"
    return 0
}

# ============================================================================
# 7. VALIDATION CSRF - TOUS LES POST DOIVENT VERIFIER
# ============================================================================
check_csrf() {
    local API_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E "^public/api/.*\.php$" || true)

    if [ -z "$API_FILES" ]; then
        return 0
    fi

    echo -e "${BLUE}[7/7] Validation CSRF...${NC}"
    local errors=0

    while IFS= read -r file; do
        # Ignorer _bootstrap.php et health.php
        if [[ "$file" == *"_bootstrap"* ]] || [[ "$file" == *"health"* ]]; then
            continue
        fi

        # Verifier si le fichier gere POST
        local HAS_POST=$(git diff --cached "$file" 2>/dev/null | grep -E "^\+" | grep -iE "\\\$_POST|\\\$_REQUEST.*POST|method.*POST" || true)
        if [ -n "$HAS_POST" ]; then
            # Verifier si CSRF est verifie
            local HAS_CSRF=$(grep -iE "requireCsrf|verify_csrf|csrf_token" "$file" 2>/dev/null || true)
            if [ -z "$HAS_CSRF" ]; then
                echo -e "${YELLOW}   CSRF: $file - POST sans verification CSRF${NC}"
                WARNINGS=$((WARNINGS + 1))
            fi
        fi
    done <<< "$API_FILES"

    echo -e "${GREEN}   CSRF OK${NC}"
    return 0
}

# ============================================================================
# EXECUTION DES VALIDATIONS
# ============================================================================

check_php_syntax
check_mvc
check_paths
check_i18n
check_uploads
check_secrets
check_csrf

# ============================================================================
# RESULTAT FINAL
# ============================================================================

END_TIME=$(date +%s 2>/dev/null || echo "0")
DURATION=$((END_TIME - START_TIME))

echo ""
echo -e "${DIM}Temps d'execution: ${DURATION}s${NC}"
echo ""

if [ $ERRORS -gt 0 ]; then
    echo -e "${RED}+===================================================================${NC}"
    echo -e "${RED}|  COMMIT BLOQUE - $ERRORS erreur(s) detectee(s)                   ${NC}"
    echo -e "${RED}+===================================================================${NC}"
    echo ""
    echo -e "${YELLOW}Solutions:${NC}"
    echo "  1. Corriger les erreurs indiquees ci-dessus"
    echo "  2. Consulter CLAUDE.md pour les regles du projet"
    echo "  3. Bypass temporaire: git commit --no-verify (deconseille)"
    echo ""
    exit 1
fi

if [ $WARNINGS -gt 0 ]; then
    echo -e "${YELLOW}+===================================================================${NC}"
    echo -e "${YELLOW}|  COMMIT AUTORISE - $WARNINGS warning(s) a corriger               ${NC}"
    echo -e "${YELLOW}+===================================================================${NC}"
    echo ""
else
    echo -e "${GREEN}+===================================================================${NC}"
    echo -e "${GREEN}|  TOUTES LES VALIDATIONS PASSENT - Commit autorise              ${NC}"
    echo -e "${GREEN}+===================================================================${NC}"
    echo ""
fi

exit 0
