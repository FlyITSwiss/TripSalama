{
  "appId": "com.tripsalama.app",
  "appName": "TripSalama",
  "webDir": "public",
  "bundledWebRuntime": false,
  "server": {
    "androidScheme": "https",
    "iosScheme": "https",
    "allowNavigation": [
      "https://stabilis-it.ch/*",
      "https://*.stripe.com/*",
      "https://*.openstreetmap.org/*",
      "https://unpkg.com/*"
    ]
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2000,
      "launchAutoHide": true,
      "backgroundColor": "#2D5A4A",
      "androidSplashResourceName": "splash",
      "iosSplashResourceName": "Splash",
      "showSpinner": false,
      "spinnerColor": "#D4AF37"
    },
    "StatusBar": {
      "style": "dark",
      "backgroundColor": "#2D5A4A",
      "overlaysWebView": true
    },
    "Keyboard": {
      "resize": "none",
      "resizeOnFullScreen": false,
      "style": "dark"
    },
    "PushNotifications": {
      "presentationOptions": ["badge", "sound", "alert"]
    },
    "Geolocation": {
      "enableHighAccuracy": true,
      "timeout": 15000,
      "maximumAge": 0
    },
    "Haptics": {
      "enabled": true
    },
    "Camera": {
      "saveToGallery": false,
      "quality": 80,
      "width": 1024,
      "height": 1024,
      "preserveAspectRatio": true,
      "correctOrientation": true,
      "promptLabelHeader": "Photo",
      "promptLabelPhoto": "Galerie",
      "promptLabelPicture": "Camera"
    },
    "Network": {
      "connectionType": "any"
    },
    "BackgroundGeolocation": {
      "distanceFilter": 10,
      "desiredAccuracy": "high",
      "stationaryRadius": 25,
      "stopOnTerminate": false,
      "startOnBoot": true,
      "notificationTitle": "TripSalama",
      "notificationText": "Course en cours...",
      "debug": false
    }
  },
  "android": {
    "allowMixedContent": true,
    "captureInput": true,
    "webContentsDebuggingEnabled": true,
    "loggingBehavior": "debug",
    "backgroundColor": "#2D5A4A",
    "buildOptions": {
      "keystorePath": "release.keystore",
      "keystoreAlias": "tripsalama"
    }
  },
  "ios": {
    "contentInset": "automatic",
    "scrollEnabled": true,
    "backgroundColor": "#2D5A4A",
    "limitsNavigationsToAppBoundDomains": true,
    "preferredContentMode": "mobile"
  }
}
