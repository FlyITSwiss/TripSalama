# TripSalama - Configuration Environnement
# Copier vers .env et adapter selon l'environnement

# ============================================
# APPLICATION
# ============================================
APP_NAME=TripSalama
APP_ENV=local
# APP_ENV=production
APP_DEBUG=true
# APP_DEBUG=false (production)
APP_URL=http://127.0.0.1:8080
# APP_URL=https://tripsalama.stabilis-it.ch (production)

# Base Path (vide pour local)
BASE_PATH=
# BASE_PATH=/tripsalama (si sous-dossier)

# ============================================
# DATABASE - LOCAL (Docker)
# ============================================
DB_HOST=tripsalama-db
DB_PORT=3306
DB_DATABASE=tripsalama
DB_USERNAME=tripsalama
DB_PASSWORD=tripsalama_secret

# ============================================
# DATABASE - INFOMANIAK (Production)
# ============================================
# DB_HOST=xxxxx.myd.infomaniak.com
# DB_PORT=3306
# DB_DATABASE=xxxxx_tripsalama
# DB_USERNAME=xxxxx_tripsalama
# DB_PASSWORD=VotreMotDePasseSecurise

# ============================================
# SESSION
# ============================================
SESSION_LIFETIME=120
SESSION_SECURE=false
# SESSION_SECURE=true (production avec HTTPS)

# ============================================
# LOCALISATION
# ============================================
DEFAULT_LANG=fr
TIMEZONE=Africa/Casablanca

# ============================================
# UPLOADS
# ============================================
UPLOAD_MAX_SIZE=5242880
ALLOWED_EXTENSIONS=jpg,jpeg,png,gif,pdf

# ============================================
# MAP / GEOCODING
# ============================================
# Nominatim (OSM) - gratuit mais limite
NOMINATIM_URL=https://nominatim.openstreetmap.org
NOMINATIM_USER_AGENT=TripSalama/1.0

# OSRM Routing
OSRM_URL=https://router.project-osrm.org

# ============================================
# PRICING
# ============================================
PRICE_BASE=8.00
PRICE_PER_KM=3.50
PRICE_PER_MIN=0.50
CURRENCY=MAD

# ============================================
# COMMISSION
# ============================================
# Taux de commission plateforme (0.15 = 15%)
PLATFORM_COMMISSION_RATE=0.15

# ============================================
# STRIPE PAYMENTS
# ============================================
# Cles API Stripe (https://dashboard.stripe.com/apikeys)
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxx
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxx
# Webhook secret pour verifier les signatures
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxx

# ============================================
# SECURITY
# ============================================
# Cle de chiffrement pour coordonnees GPS sensibles
# Generer avec: php -r "echo bin2hex(random_bytes(32));"
COORDINATES_ENCRYPTION_KEY=

# ============================================
# PUSH NOTIFICATIONS
# ============================================
# Firebase Cloud Messaging (Android)
FCM_SERVER_KEY=

# Apple Push Notifications (iOS)
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_BUNDLE_ID=ch.stabilis-it.tripsalama
APNS_KEY_FILE=

# ============================================
# SMS (Twilio)
# ============================================
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ============================================
# EMAIL (SMTP)
# ============================================
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=noreply@tripsalama.com
MAIL_FROM_NAME=TripSalama

# ============================================
# 2FA / OTP
# ============================================
# Duree de validite du code OTP en minutes
OTP_EXPIRY_MINUTES=10
# Longueur du code OTP
OTP_LENGTH=6

# ============================================
# PRAYER TIMES API
# ============================================
# API Aladhan pour les horaires de priere
PRAYER_API_URL=https://api.aladhan.com/v1
# Methode de calcul (2=ISNA, 3=MWL, 4=Makkah, 5=Egypt, 21=Morocco)
PRAYER_CALCULATION_METHOD=21

# ============================================
# INSURANCE
# ============================================
# Partenaire assurance
INSURANCE_PROVIDER=
INSURANCE_POLICY_NUMBER=
INSURANCE_CERTIFICATE_URL=
